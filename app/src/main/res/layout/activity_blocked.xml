<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:background="#0A0A0F" android:padding="32dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🔒" android:textSize="80sp" android:layout_marginBottom="20dp"/>

    <TextView android:id="@+id/tvBlockedName" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="🚫 App is blocked"
        android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold"
        android:gravity="center" android:layout_marginBottom="12dp"/>

    <TextView android:id="@+id/tvCountdown" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="25:00 remaining"
        android:textColor="#7C6BFF" android:textSize="18sp" android:fontFamily="monospace"
        android:textStyle="bold" android:layout_marginBottom="20dp"/>

    <TextView android:id="@+id/tvModeInfo" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="This app is blocked."
        android:textColor="#8888AA" android:textSize="14sp" android:gravity="center"
        android:lineSpacingMultiplier="1.5" android:background="#16161F"
        android:padding="16dp" android:layout_marginBottom="12dp"/>

    <TextView android:id="@+id/tvQuote" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text=""
        android:textColor="#6BFFC8" android:textSize="15sp" android:gravity="center"
        android:lineSpacingMultiplier="1.4" android:textStyle="italic"
        android:layout_marginBottom="36dp"/>

    <Button android:id="@+id/btnGoHome" android:layout_width="240dp" android:layout_height="52dp"
        android:text="← Go to Home Screen" android:textColor="#FFFFFF"
        android:textSize="15sp" android:textStyle="bold" android:backgroundTint="#7C6BFF"
        android:layout_marginBottom="12dp"/>

    <Button android:id="@+id/btnEndSession" android:layout_width="240dp" android:layout_height="44dp"
        android:text="End Session" android:textColor="#666688" android:textSize="14sp"
        android:backgroundTint="#16161F"/>

</LinearLayout>
